{
  "manifest_version": 3,
  "name": "Judol Detector",
  "version": "1.0",
  "description": "Detects and marks suspicious judi online text on web pages.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
